# Copy to .env and fill in. Never commit the real .env.

# Master switch — see plan.md §2.3
# When false, providers with paid: true in providers.yaml are SKIPPED.
ALLOW_PAID=false

# OpenRouter (free tier works without account, paid models need a key)
# OPENROUTER_API_KEY=sk-or-v1-...

# Where to load providers.yaml from. If unset, CodeRouter searches
# ./providers.yaml then ~/.coderouter/providers.yaml.
# CODEROUTER_CONFIG=/absolute/path/to/providers.yaml
