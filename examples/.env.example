# Copy to .env and fill in. Never commit the real .env.
#
# How to load:
#   `source .env`                    works because every line uses `export`.
#                                    Variables become real env vars and are
#                                    inherited by `coderouter serve` /
#                                    `coderouter doctor`.
#   `set -a && source .env && set +a` works too; auto-exports plain KEY=VAL.
#
# CodeRouter itself does NOT auto-load `.env` — you have to source it
# yourself (or use a tool like direnv) BEFORE running coderouter.
#
# Verify after sourcing:
#   env | grep -E 'OPENROUTER|NVIDIA|ANTHROPIC|ALLOW_PAID'
# (the keys you set should appear; if not, `export` is missing.)

# ---------------------------------------------------------------
# Master switch — see plan.md §2.3
# When false, providers with paid: true in providers.yaml are SKIPPED.
# ---------------------------------------------------------------
export ALLOW_PAID=false

# ---------------------------------------------------------------
# OpenRouter
# Free tier works without an account, but the `:free` SKUs in
# examples/providers.yaml all reference this var via `api_key_env`.
# Without it, those entries are skipped (the chain still falls
# through to the next provider).
# Sign up: https://openrouter.ai/  → Keys
# ---------------------------------------------------------------
# export OPENROUTER_API_KEY=sk-or-v1-...

# ---------------------------------------------------------------
# NVIDIA NIM (free developer tier — see examples/providers.nvidia-nim.yaml)
# 40 req/min, initial credit grant.
# Sign up: https://build.nvidia.com → API Keys
# Format: nvapi-...
# ---------------------------------------------------------------
# export NVIDIA_NIM_API_KEY=nvapi-...

# ---------------------------------------------------------------
# Anthropic direct (paid — only used when ALLOW_PAID=true and
# the active profile lists `anthropic-direct`)
# Sign up: https://console.anthropic.com
# ---------------------------------------------------------------
# export ANTHROPIC_API_KEY=sk-ant-...

# ---------------------------------------------------------------
# Where to load providers.yaml from. If unset, CodeRouter searches
# ./providers.yaml then ~/.coderouter/providers.yaml.
# ---------------------------------------------------------------
# export CODEROUTER_CONFIG=/absolute/path/to/providers.yaml
